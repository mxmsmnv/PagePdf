        $f = $modules->get('InputfieldCheckbox');
        $f->name = 'enable_header';
        $f->label = __('Enable Header');
        $f->checked = isset($data['enable_header']) ? $data['enable_header'] : false;
        $f->columnWidth = 50;
        $fieldset->add($f);

        $f = $modules->get('InputfieldText');
        $f->name = 'header_text';
        $f->label = __('Header Text');
        $f->description = __('Variables: {PAGENO}, {DATE}, {sitename}');
        $f->value = isset($data['header_text']) ? $data['header_text'] : '';
        $f->showIf = 'enable_header=1';
        $f->columnWidth = 50;
        $fieldset->add($f);

        $f = $modules->get('InputfieldCheckbox');
        $f->name = 'enable_footer';
        $f->label = __('Enable Footer');
        $f->checked = isset($data['enable_footer']) ? $data['enable_footer'] : true;
        $f->columnWidth = 50;
        $fieldset->add($f);

        $f = $modules->get('InputfieldText');
        $f->name = 'footer_text';
        $f->label = __('Footer Text');
        $f->description = __('Variables: {PAGENO}, {nbpg}, {DATE}, {sitename}');
        $f->value = isset($data['footer_text']) ? $data['footer_text'] : '{PAGENO} / {nbpg}';
        $f->showIf = 'enable_footer=1';
        $f->columnWidth = 50;
        $fieldset->add($f);

        $inputfields->add($fieldset);

        // Watermark
        $fieldset = $modules->get('InputfieldFieldset');
        $fieldset->label = __('Watermark');
        $fieldset->collapsed = Inputfield::collapsedYes;

        $f = $modules->get('InputfieldText');
        $f->name = 'watermark_text';
        $f->label = __('Watermark Text');
        $f->description = __('Leave empty to disable watermark');
        $f->value = isset($data['watermark_text']) ? $data['watermark_text'] : '';
        $f->columnWidth = 70;
        $fieldset->add($f);

        $f = $modules->get('InputfieldFloat');
        $f->name = 'watermark_alpha';
        $f->label = __('Watermark Opacity');
        $f->description = __('0.0 (transparent) to 1.0 (opaque)');
        $f->value = isset($data['watermark_alpha']) ? $data['watermark_alpha'] : 0.1;
        $f->min = 0;
        $f->max = 1;
        $f->precision = 2;
        $f->columnWidth = 30;
        $fieldset->add($f);

        $inputfields->add($fieldset);

        // Security
        $fieldset = $modules->get('InputfieldFieldset');
        $fieldset->label = __('Security');
        $fieldset->collapsed = Inputfield::collapsedYes;

        $f = $modules->get('InputfieldCheckbox');
        $f->name = 'enable_protection';
        $f->label = __('Enable PDF Protection');
        $f->description = __('Restrict copying and printing');
        $f->checked = isset($data['enable_protection']) ? $data['enable_protection'] : false;
        $fieldset->add($f);

        $f = $modules->get('InputfieldText');
        $f->name = 'user_password';
        $f->label = __('User Password');
        $f->description = __('Password to open PDF (leave empty for no password)');
        $f->value = isset($data['user_password']) ? $data['user_password'] : '';
        $f->showIf = 'enable_protection=1';
        $f->columnWidth = 50;
        $fieldset->add($f);

        $f = $modules->get('InputfieldText');
        $f->name = 'owner_password';
        $f->label = __('Owner Password');
        $f->description = __('Password for full permissions');
        $f->value = isset($data['owner_password']) ? $data['owner_password'] : '';
        $f->showIf = 'enable_protection=1';
        $f->columnWidth = 50;
        $fieldset->add($f);

        $inputfields->add($fieldset);

        return $inputfields;
    }
}
